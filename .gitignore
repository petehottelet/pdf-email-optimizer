# Project working files (design assets, drafts, scratch)
00_project_files/

# QA render output from compare_pdf_render.py
qa-renders/

# Scratch render output (from comparing PDFs locally)
output/

# Test/sample PDFs and generated output
*.pdf

# ...but keep the redistributable, synthetic benchmark fixtures (CC0).
!benchmarks/fixtures/*.pdf

# Transient harness output (regenerated each run)
benchmarks/results/generated-pdfs/

# Generated demonstration brochures + their optimized copies/reports.
# Rebuild with: python benchmarks/make_demo_brochures.py
# The small before/after renders in docs/gallery/ ARE committed.
demo/

# Local-only real-world benchmark fixtures. Public ones live under
# benchmarks/corpus/public/ and are committed individually when redistributable.
benchmarks/corpus/private/*
!benchmarks/corpus/private/README.md

